[Unit]
Description=Bandwidth Test Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=bwtest
Group=bwtest
WorkingDirectory=/opt/bwtest
EnvironmentFile=-/etc/default/bwagent
ExecStart=/usr/local/bin/bwagent /etc/bwagent/config.json
Restart=always
RestartSec=3
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
